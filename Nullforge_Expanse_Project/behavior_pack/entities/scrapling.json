{
  "format_version": "1.16.0",
  "minecraft:entity": {
    "description": {
      "identifier": "nullforge:scrapling",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },
    "components": {
      "minecraft:type_family": {
        "family": ["scrapling", "monster"]
      },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0
      },
      "minecraft:collision_box": {
        "width": 0.6,
        "height": 1.9
      },
      "minecraft:health": {
        "value": 20,
        "max": 20
      },
      "minecraft:loot": {
        "table": "loot_tables/entities/scrapling.json"
      },
      "minecraft:damage_sensor": {
        "triggers": [
          {
            "on_damage": {
              "filters": [
                {
                  "test": "has_damage",
                  "value": "fatal"
                }
              ]
            }
          }
        ]
      },
      "minecraft:attack": {
        "damage": 3
      },
      "minecraft:can_climb": {},
      "minecraft:equipment": {
        "table": "loot_tables/entities/scrapling_gear.json"
      },
      "minecraft:pushable": {
        "is_pushable": true,
        "is_pushable_by_piston": true
      },
      "minecraft:conditional_bandwidth_optimization": {
        "default_values": {
          "max_optimized_distance": 80.0,
          "max_dropped_ticks": 10,
          "use_motion_prediction_hints": true
        }
      }
    },
    "component_groups": {
      "minecraft:angry": {
        "minecraft:angry": {
          "duration": 25,
          "calm_event": {
            "event": "minecraft:on_calm"
          }
        }
      }
    },
    "events": {
      "minecraft:entity_spawned": {
        "add": {
          "component_groups": ["minecraft:angry"]
        }
      },
      "minecraft:on_calm": {
        "remove": {
          "component_groups": ["minecraft:angry"]
        }
      }
    }
  }
}